---
import { getCollection } from "astro:content";
import Layout from "~/components/layout.astro";
import Table from "~/components/result-table.astro";
import { getLangFromUrl, useTranslations } from "~/utils/i18n";

const results = await getCollection("results");
const sortedResults = results.sort((a, b) => b.data.year - a.data.year);
const years = Array.from(new Set(sortedResults.map((r) => r.data.year))).sort((a, b) => b - a);
console.log(sortedResults);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations("results", lang);
---

<Layout
  title={t("tasks_header")}
  description={t("tasks_description")}
  image="/photos/awards-ceremony.jpg"
>
  <!-- Filters bar -->
  <div class="col-span-full mb-6 flex flex-wrap gap-3 items-end justify-center max-w-5xl mx-auto">
    <div>
      <label for="yearFilter" class="block text-sm text-neutral-500 mb-1">{t("filters.year")}</label>
      <select id="yearFilter" class="min-w-48 border border-neutral-300 rounded-md px-3 py-2 bg-white">
        <option value="all">{t("filters.all")}</option>
        {years.map((y) => (
          <option value={y}>{y}</option>
        ))}
      </select>
    </div>
    <div>
      <label for="leagueFilter" class="block text-sm text-neutral-500 mb-1">{t("filters.league")}</label>
      <select id="leagueFilter" class="min-w-48 border border-neutral-300 rounded-md px-3 py-2 bg-white">
        <option value="all">{t("filters.all")}</option>
        <option value="senior">{t("senior_league")}</option>
        <option value="junior">{t("junior_league")}</option>
      </select>
    </div>
  </div>
  <!-- Sidebar removed; tasks moved inline above each section -->

  {
    sortedResults.map((table_result) => (
      <>
        <section class="result-block col-span-full grid grid-cols-subgrid" data-year={table_result.data.year} data-league="senior">
          <div class="col-span-full pt-6 text-center">
            <h3 class="text-neutral-400 text-xl">{table_result.data.year}</h3>
            <h2 class="text-neutral-900 text-4xl md:text-5xl font-bold uppercase mb-2">{t("senior_league")}</h2>
          </div>
          {table_result.data.year === 2025 && (
            <div class="col-span-full flex flex-wrap gap-3 mb-4 justify-center">
              <a href="/tasks/qualifier_results_2025.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_results")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2025</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
            </div>
          )}
          {table_result.data.year === 2024 && (
            <div class="col-span-full flex flex-wrap gap-3 mb-4 justify-center">
              <a href="/tasks/qualifier_results_2024.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_results")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
              <a href="/tasks/disqualification_protocol_2024.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_disqualification")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
              <a href="/tasks/senior_qualifier_2024_kz_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("senior_qualifier")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_kaz")}</div></a>
              <a href="/tasks/senior_final_2024_kaz.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("senior_final")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_kaz")}</div></a>
              <a href="/tasks/senior_qualifier_2024_ru_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("senior_qualifier")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
              <a href="/tasks/senior_final_2024_ru.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("senior_final")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
            </div>
          )}
          {table_result.data.year === 2023 && (
            <div class="col-span-full flex flex-wrap gap-3 mb-4 justify-center">
              <a href="https://docs.google.com/spreadsheets/d/1Y7ukztnvBRyyBMOQfX7wlGEbryBA3FZfRYT1Lqmrmio/edit?gid=0#gid=0" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_results")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2023</div></a>
              <a href="/tasks/senior_qualifier_2023_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("senior_qualifier")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2023</div></a>
              <a href="/tasks/senior_final_2023_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("senior_final")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2023</div></a>
            </div>
          )}
          <Table className="col-span-full lg:col-span-10 lg:col-start-2 w-full max-w-6xl mx-auto" results={table_result.data.senior} />
        </section>

        <section class="result-block col-span-full grid grid-cols-subgrid" data-year={table_result.data.year} data-league="junior">
          <div class="col-span-full pt-6 mt-16 text-center">
            <h3 class="text-neutral-400 text-xl">{table_result.data.year}</h3>
            <h2 class="text-neutral-900 text-4xl md:text-5xl font-bold uppercase mb-2">{t("junior_league")}</h2>
          </div>
          {table_result.data.year === 2025 && (
            <div class="col-span-full flex flex-wrap gap-3 mb-4 justify-center">
              <a href="/tasks/qualifier_results_2025.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_results")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2025</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
            </div>
          )}
          {table_result.data.year === 2024 && (
            <div class="col-span-full flex flex-wrap gap-3 mb-4 justify-center">
              <a href="/tasks/qualifier_results_2024.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_results")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
              <a href="/tasks/disqualification_protocol_2024.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_disqualification")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
              <a href="/tasks/junior_qualifier_2024_kz_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("junior_qualifier")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_kaz")}</div></a>
              <a href="/tasks/junior_final_2024_kaz.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("junior_final")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_kaz")}</div></a>
              <a href="/tasks/junior_qualifier_2024_ru_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("junior_qualifier")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
              <a href="/tasks/junior_final_2024_rus.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("junior_final")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2024</div><div class="absolute right-12 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">{t("label_rus")}</div></a>
            </div>
          )}
          {table_result.data.year === 2023 && (
            <div class="col-span-full flex flex-wrap gap-3 mb-4 justify-center">
              <a href="https://docs.google.com/spreadsheets/d/1Y7ukztnvBRyyBMOQfX7wlGEbryBA3FZfRYT1Lqmrmio/edit?gid=0#gid=0" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("qualifier_results")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2023</div></a>
              <a href="/tasks/junior_qualifier_2023_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("junior_qualifier")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2023</div></a>
              <a href="/tasks/junior_final_2023_sols.pdf" class="p-2 rounded-lg text-secondary relative bg-primary-700 text-lg">{t("junior_final")}<div class="absolute right-2 rounded-md bottom-0 translate-y-1/2 text-xs bg-primary-900 px-1 py-0.5">2023</div></a>
            </div>
          )}
          <Table className="col-span-full lg:col-span-10 lg:col-start-2 w-full max-w-6xl mx-auto" results={table_result.data.junior} />
        </section>
      </>
    ))
  }

  <script>
    const yearSelect = document.getElementById('yearFilter');
    const leagueSelect = document.getElementById('leagueFilter');

    function applyFilters() {
      const year = (yearSelect && (yearSelect as HTMLSelectElement).value) || 'all';
      const league = (leagueSelect && (leagueSelect as HTMLSelectElement).value) || 'all';
      document.querySelectorAll<HTMLElement>('.result-block').forEach((el) => {
        const y = el.dataset.year;
        const l = el.dataset.league;
        const yearOk = year === 'all' || y === year;
        const leagueOk = league === 'all' || l === league;
        el.classList.toggle('hidden', !(yearOk && leagueOk));
      });
    }

    yearSelect?.addEventListener('change', applyFilters);
    leagueSelect?.addEventListener('change', applyFilters);
    applyFilters();
  </script>
</Layout>
