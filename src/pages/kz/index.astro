    {t("league.older.description")}
    <br />
  </p>
  <h4
    class="md:col-span-4 col-span-2 text-neutral-500 md:text-3xl row-span-1 mb-32"
    data-speed="1.05"
  >
    {t("league.younger")}
  </h4>
  <p
    class="md:col-span-4 col-span-2 md:text-3xl row-span-1 mb-32"
    data-speed="1.05"
  >
    {t("league.younger.description")}
  </p>
  <div
