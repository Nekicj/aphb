              title="YouTube video player" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              referrerpolicy="strict-origin-when-cross-origin" 
              allowfullscreen
              class="w-full h-full">
            </iframe>
          </div>
          
          <p class="text-center text-lg font-semibold text-blue-900 mb-8">
            Репортаж Almaty TV с APhB 2024
          </p>
          
          <!-- Логотипы партнёров -->
          <div class="bg-white rounded-2xl p-6 shadow-md">
            <h4 class="text-center text-lg font-bold text-gray-800 mb-6">Партнёры 2024</h4>
            <div class="space-y-6">
              <!-- Основные логотипы -->
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 place-items-center">
                <img src="/partners/almaty-daryny.svg" alt="Almaty Daryny" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/chevron.svg" alt="Chevron" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/caravan.svg" alt="Caravan" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/lenovo.svg" alt="Lenovo" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/nis.svg" alt="NIS" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/sunmary.svg" alt="Sunmary" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/umag.svg" alt="UMag" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/ustem.svg" alt="USTEM" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/wolfram-alpha.svg" alt="Wolfram Alpha" class="h-14 md:h-16 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/zapis.svg" alt="Zapis" class="h-12 md:h-14 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
              </div>
              
              <!-- Министерства -->
              <div class="border-t border-gray-200 pt-4">
                <div class="flex justify-center gap-8">
                  <img src="/partners/ministry-of-education.svg" alt="Ministry of Education" class="h-8 md:h-10 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                  <img src="/partners/mnvo.svg" alt="MNVO" class="h-8 md:h-10 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="lg:order-2">
          <h2 class="text-3xl lg:text-5xl font-bold mb-8">Прорыв 2024 года</h2>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            Мы бросили себе вызов — провести турнир целую неделю на базе Satbayev University. Впервые в истории Центральной Азии одновременно прошли APhB и National Chemical Battles.
          </p>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            <strong>Более 1000 участников</strong> из Казахстана, России, Кыргызстана, Узбекистана, Таджикистана и Беларуси. Впервые приехали иностранные команды — из СУНЦ МГУ и официальная сборная Республики Башкортостан.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3.5. Отзыв от Satbayev University -->
  <section class="col-span-full mb-20">
    <div class="max-w-4xl mx-auto">
      <blockquote class="bg-white border border-neutral-200 rounded-2xl p-8 lg:p-12 text-center">
        <p class="text-xl lg:text-2xl font-semibold text-neutral-800 mb-6 leading-relaxed">
          «APhB — организаторы, с которыми приятно работать: четкая коммуникация, высокая планка академического содержания и внимание к участникам. Мы рады поддерживать развитие олимпиадного движения»
        </p>
        <footer class="text-neutral-600 text-lg">
          Марс Нарбаев, Руководитель Офиса формирования контингента обучающихся Satbayev University
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- 4. Команда и волонтёры -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl lg:text-5xl font-bold mb-8">Люди, которые делают чудеса</h2>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            <strong>За два года было создано более 150 задач</strong> командой лучших олимпиадников Казахстана, России, и не только: школьниками и студентами MIT, Williams College, Notre Dame, Grinnell College NYU, HKUST, CityU, KAIST, Назарбаев Университета, и МФТИ. Среди которых бывшие и нынешние члены жюри и составители задач Всероссийской Олимпиады Школьников, Республиканской Олимпиады РК, Международной Жаутыковской Олимпиады, Олимпиады ЛФИ, и других!
          </p>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            Жюри из 6 городов работали по 12 часов в день. Волонтёры приехали со всей страны и даже из Ташкента — встречали в аэропорту, водили в походы на Бутаковский водопад, дежурили ночами в общежитии.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
            <div class="rounded-xl overflow-hidden">
              <img src={volunteer1Photo} alt="Волонтёры APhB" class="w-full h-48 object-cover" />
            </div>
            <div class="rounded-xl overflow-hidden">
              <img src={volunteer2Photo} alt="Волонтёры APhB" class="w-full h-48 object-cover" />
            </div>
            <div class="rounded-xl overflow-hidden">
              <img src={volunteer3Photo} alt="Волонтёры APhB" class="w-full h-48 object-cover" />
            </div>
          </div>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            Сотни часов волонтёрской работы, бессонные ночи — всё ради того, чтобы дать ребятам незабываемый опыт.
          </p>
        </div>
        <div class="bg-neutral-100 rounded-2xl p-8 text-center">
          <div class="w-full h-64 rounded-xl mb-4 overflow-hidden">
            <img src={volunteersPhoto} alt="Команда волонтёров и организаторов" class="w-full h-full object-cover" />
          </div>
          <p class="text-neutral-600">Команда жюри 2024 года</p>  
        </div>
      </div>
    </div>
  </section>

  <!-- 4.5. Признание на государственном уровне -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl lg:text-5xl font-bold text-center mb-8">Признание на государственном уровне</h2>
      <p class="text-center text-lg text-neutral-600 mb-12 max-w-3xl mx-auto">
        APhB получил официальное признание от Министерства науки и высшего образования РК и стал частью важных государственных инициатив
      </p>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Расширенное заседание коллегии -->
        <div class="bg-gradient-to-br from-green-50 to-emerald-100 border-2 border-green-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 hover:scale-105">
          <div class="w-full h-48 rounded-xl mb-4 overflow-hidden border-2 border-white shadow-md">
            <img src="/photos/rashir.png" alt="Расширенное заседание коллегии Министерства науки и высшего образования РК" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold text-green-900 mb-3">Заседание коллегии Министерства</h3>
          <p class="text-green-800 text-sm leading-relaxed font-medium">
            Министерства науки и высшего образования РК «Качественное образование – качественный человеческий капитал»
          </p>
        </div>

        <!-- Встреча с министром -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-100 border-2 border-blue-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 hover:scale-105">
          <div class="w-full h-48 rounded-xl mb-4 overflow-hidden border-2 border-white shadow-md">
            <img src="/photos/minister.png" alt="Встреча с министром науки и высшего образования РК" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold text-blue-900 mb-3">Встреча с министром</h3>
          <p class="text-blue-800 text-sm leading-relaxed font-medium">
            Оргкомитет на личной встрече с министром науки и высшего образования РК Саясат Нурбеком
          </p>
        </div>

        <!-- Международный опыт -->
        <div class="bg-gradient-to-br from-purple-50 to-violet-100 border-2 border-purple-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 hover:scale-105">
          <div class="w-full h-48 rounded-xl mb-4 overflow-hidden border-2 border-white shadow-md">
            <img src="/photos/izho.png" alt="Обмен опытом с организатором IZhO 2024" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold text-purple-900 mb-3">Международный опыт</h3>
          <p class="text-purple-800 text-sm leading-relaxed font-medium">
            Перенимаем опыт организации международных олимпиад у организатора IZhO 2024 - директора РФМШ г. Алматы, Меирбека Меирлана Едигерулы
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Поход в горы -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="bg-neutral-100 rounded-2xl p-8 text-center lg:order-1">
          <div class="w-full h-64 rounded-xl mb-4 overflow-hidden relative">
            <video 
              src={mountainHikeVideo} 
              autoplay 
              muted
              loop 
              playsinline
              class="w-full h-full object-cover"
              aria-label="Поход на Бутаковский водопад в горах Заилийского Алатау"
              controls>
            </video>
          </div>
        </div>
        <div class="lg:order-2">
          <h2 class="text-3xl lg:text-5xl font-bold mb-8">Больше чем турнир</h2>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            APhB — это не только физика. Во время турниров у нас было много развлечений, воркшопов, и нетворкинг-ивентов. Это походы в музей Кастеева и к Бутаковскому водопаду в горах Заилийского Алатау, лекции от профессоров Назарбаев Университета, гитарные вечера, футбольные турниры, и многое другое!
          </p>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            Это вечера кино, новые друзья из разных стран, и воспоминания на всю жизнь. Один участник даже пошёл в горы в шлёпках — просто не знал, что будет поход!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Партнёры -->
  {logos.length > 0 && (
    <section class="col-span-full mb-20">
      <h2 class="text-3xl lg:text-5xl font-bold text-center mb-8">Партнёры, которые поверили в нас</h2>
      <p class="text-center text-lg text-neutral-600 mb-12 max-w-3xl mx-auto">
        Впервые были установлены партнёрства с государством — Министерством науки и высшего образования РК, а также с ведущими компаниями и образовательными учреждениями
      </p>
      <div class="bg-white border border-neutral-200 rounded-2xl p-8 lg:p-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-8 lg:gap-12 place-items-center">
          {logos.map((logo) => (
            <div class="flex items-center justify-center p-4 hover:bg-neutral-50 rounded-xl transition-all duration-300 hover:scale-105">
              <img 
                src={logo.src} 
                alt={logo.alt} 
                loading="lazy" 
                class="max-h-12 lg:max-h-16 xl:max-h-20 w-auto object-contain opacity-75 hover:opacity-100 transition-opacity duration-300" 
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 7. Отзывы участников -->
