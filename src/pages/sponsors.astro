        {testimonials.map((testimonial) => (
          <div class="bg-white border border-neutral-200 rounded-2xl p-6">
            <p class="text-neutral-700 mb-4 leading-relaxed">
              "{testimonial.text}"
            </p>
            <div class="border-t border-neutral-200 pt-4">
              <p class="font-semibold text-neutral-800">{testimonial.author}</p>
              {testimonial.team && <p class="text-sm text-neutral-600">Команда "{testimonial.team}"</p>}
              <p class="text-sm text-neutral-500">{testimonial.school}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


