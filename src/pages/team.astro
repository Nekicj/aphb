---
import { getCollection } from "astro:content";
import TeamMember from "~/components/team-member.astro";
import Layout from "~/components/layout.astro";
import { getLangFromUrl } from "~/utils/i18n";

const team = await getCollection("team");
const academics = team.filter((entry) => entry.slug.startsWith("academic/"));
const executives = team.filter((entry) => entry.slug.startsWith("executive/"));
const lang = getLangFromUrl(Astro.url);
const banner = {
  ru: {
    title: "Присоединяйтесь к нашей команде",
    subtitle: "Мы ищем добровольцев, менторов и организаторов",
    cta: "Написать нам",
  },
  en: {
    title: "Join our team",
    subtitle: "We are looking for volunteers, mentors and organizers",
    cta: "Email us",
  },
  kz: {
    title: "Біздің командаға қосылыңыз",
    subtitle: "Бізге еріктілер, тәлімгерлер және ұйымдастырушылар қажет",
    cta: "Бізге жазыңыз",
  },
} as const;
const t = banner[lang as keyof typeof banner] ?? banner.ru;
---

<Layout
  title="Команда"
  grid={false}
  description="В нашей команде состоит множество бывших и нынешних членов национальной сборной Казахстана по физике, а также студенты MIT, Harvard, МФТИ и NU. "
>
  <!-- Join banner (centered) placed ABOVE academic committee banner -->
  <div class="col-span-full flex justify-center mt-6 relative z-40">
    <div class="w-full max-w-3xl relative overflow-hidden rounded-2xl border border-neutral-200 bg-white p-8 md:p-12 text-center shadow-xl">
      <div class="absolute -top-24 -left-24 h-64 w-64 rounded-full bg-primary-100 blur-3xl"></div>
      <div class="absolute -bottom-24 -right-24 h-64 w-64 rounded-full bg-primary-100 blur-3xl"></div>
      <div class="relative z-10">
        <h2 class="text-3xl md:text-5xl font-extrabold text-primary-900">{t.title}</h2>
        <p class="text-neutral-600 md:text-xl mt-2 mb-6">{t.subtitle}</p>
        <a href="mailto:administrator@aphb.kz" class="relative z-40 inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary-600 hover:bg-primary-700 text-white text-lg font-semibold transition shadow-md" aria-label="Email administrator@aphb.kz">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M1.5 6.75A2.25 2.25 0 013.75 4.5h16.5a2.25 2.25 0 012.25 2.25v10.5a2.25 2.25 0 01-2.25 2.25H3.75A2.25 2.25 0 011.5 17.25V6.75zm2.64-.75l7.11 5.333a1.5 1.5 0 001.8 0L20.16 6h-16.02z"/></svg>
          {t.cta}
        </a>
      </div>
    </div>
  </div>

  <div
    class="col-span-full bg-primary-900 p-3 lg:p-6 text-3xl lg:text-8xl font-bold rounded-xl lg:rounded-3xl relative overflow-clip my-5 lg:my-20"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1431 157"
      fill="none"
      class="absolute inset-0 h-full lg:h-auto"
    >
      <path
        d="M693.47 152.008L-45.5 15.5M693.47 152.008L230.5 -67.5M693.47 152.008L546.001 -33.9992M693.47 152.008L808.001 -33.9992M693.47 152.008L1084.5 -67.5M693.47 152.008L1461.5 15.5M693.47 152.008L1470.5 152.008M693.47 152.008L-134.001 139.5"
        stroke="#163BA4"
        stroke-width="64"
        class=""></path>
    </svg>
    <h1 class="relative text-white text-center">Академический комитет</h1>
  </div>

  {
    academics.map((academic) => (
      <TeamMember
        member={academic.data}
        className="col-span-full"
        id={academic.id}
      />
    ))
  }
  <div
    class="col-span-full bg-primary-900 p-3 lg:p-6 text-3xl lg:text-8xl font-bold rounded-xl lg:rounded-3xl relative overflow-clip my-5 lg:my-20 header-executives"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1431 157"
      fill="none"
      class="absolute inset-0 h-full lg:h-auto"
    >
      <path
        d="M693.47 152.008L-45.5 15.5M693.47 152.008L230.5 -67.5M693.47 152.008L546.001 -33.9992M693.47 152.008L808.001 -33.9992M693.47 152.008L1084.5 -67.5M693.47 152.008L1461.5 15.5M693.47 152.008L1470.5 152.008M693.47 152.008L-134.001 139.5"
        stroke="#163BA4"
        stroke-width="64"
        class="sun"></path>
    </svg>
    <h1 class="relative text-secondary text-center">Организационный комитет</h1>
  </div>
  <div class="col-span-full flex flex-col gap-5 executives">
    {
      executives.map((executive) => (
        <TeamMember member={executive.data} id={executive.id} />
      ))
    }
  </div>
  <div class="mb-20"></div>
</Layout>

<script>
  // import { gsap } from "gsap";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/all";

  gsap.registerPlugin(ScrollTrigger);
  gsap.utils.toArray(".member div").forEach((member) => {
    gsap.from(member as any, {
      scrollTrigger: {
        trigger: member as any,
        toggleActions: "restart none none none",
      },
      y: "100%",
      ease: "power4.out",
    });
  });
</script>
