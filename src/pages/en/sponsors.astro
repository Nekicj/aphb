---
import Layout from "~/components/layout.astro";
import ParticipantsMap from "~/components/participants-map";
import { participantsLocations, getTotalStats } from "~/data/participants-locations";
import { getLangFromUrl, useTranslations } from "~/utils/i18n";
import fs from "node:fs";
import path from "node:path";


const lang = getLangFromUrl(Astro.url);
const t = useTranslations("sponsors", lang);

// Use process.cwd() to get the project root directory
const publicDir = path.join(process.cwd(), "public");
const partnersBasePath = path.join(publicDir, "partners");

const allowedExtensions = [".svg", ".png", ".jpg", ".jpeg", ".webp"] as const;

function listLogosByYear(year: string) {
  const yearDir = path.join(partnersBasePath, year);
  if (!fs.existsSync(yearDir)) return [] as { src: string; alt: string }[];
  return fs
    .readdirSync(yearDir)
    .filter((file) => allowedExtensions.includes(path.extname(file).toLowerCase() as any))
    .map((file) => ({
      src: `/partners/${year}/${file}`,
      alt: file.replace(path.extname(file), "").replace(/[-_]/g, " "),
    }));
}

// Get all partner logos from the main partners directory
function getAllPartnerLogos() {
  if (!fs.existsSync(partnersBasePath)) return [];
  return fs
    .readdirSync(partnersBasePath)
    .filter((file) => allowedExtensions.includes(path.extname(file).toLowerCase() as any))
    .map((file) => ({
      src: `/partners/${file}`,
      alt: file.replace(path.extname(file), "").replace(/[-_]/g, " "),
    }));
}

const logos2023 = listLogosByYear("2023");
const logos2024 = listLogosByYear("2024");
const allPartnerLogos = getAllPartnerLogos();

// Фильтруем нежелательные логотипы
const filteredPartnerLogos = allPartnerLogos.filter(logo => 
  !logo.src.includes('el-umiti') && 
  !logo.src.includes('aues') &&
  !logo.src.includes('mephi.svg') // используем mephi_af.svg вместо mephi.svg
);

const logos = [...logos2023, ...logos2024, ...filteredPartnerLogos];

// Получаем статистику участников
const totalStats = getTotalStats();

// Импорты изображений и видео
const aphb2023Video = "/photos/IMG_1450.MP4";
const aphb2024OpeningPhoto = "/photos/aphb-2024-opening.jpg";
const volunteersPhoto = "/photos/volunteers-team.jpg";
const mountainHikeVideo = "/photos/IMG_7234.MOV";
const awardsPhoto = "/photos/awards-ceremony.jpg";
const volunteer1Photo = "/photos/volunteer-1.jpg";
const volunteer2Photo = "/photos/volunteer-2.jpg";
const volunteer3Photo = "/photos/volunteer-3.jpg";

// Testimonials
const testimonials = [
  {
    text: t("testimonials.1.text"),
    author: t("testimonials.1.author"),
    team: t("testimonials.1.team"),
    school: t("testimonials.1.school")
  },
  {
    text: t("testimonials.2.text"),
    author: t("testimonials.2.author"),
    team: t("testimonials.2.team"),
    school: t("testimonials.2.school")
  },
  {
    text: t("testimonials.3.text"),
    author: t("testimonials.3.author"),
    team: t("testimonials.3.team"),
    school: t("testimonials.3.school")
  }
];
---

<Layout title={t("seo.title")} description={t("seo.description")}>
  <!-- 1. Hero секция -->
  <div class="col-span-full bg-primary-900 p-6 lg:p-12 text-white rounded-2xl lg:rounded-3xl relative overflow-hidden my-5 lg:my-20">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 100 100"
      fill="none"
      class="absolute inset-0 w-full h-full"
      preserveAspectRatio="none"
    >
      <path
        d="M50 95L0 10M50 95L20 0M50 95L40 5M50 95L60 5M50 95L80 0M50 95L100 10M50 95L100 95M50 95L0 95"
        stroke="#163BA4"
        stroke-width="2"
        class=""></path>
    </svg>
    <div class="relative z-10 text-center max-w-4xl mx-auto">
      <h1 class="text-4xl lg:text-7xl font-bold mb-6">
        {t("hero.title")}
      </h1>
      <p class="text-lg lg:text-xl text-primary-100 mb-8 leading-relaxed">
        {t("hero.subtitle")}
      </p>
      <a href="mailto:contact@bc-pf.org" class="inline-flex items-center gap-2 bg-white text-primary-900 px-8 py-4 rounded-xl text-lg font-semibold hover:bg-primary-50 transition-colors">
        {t("hero.cta")}
      </a>
    </div>
  </div>

  <!-- 2. Начало истории - 2023 год -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl lg:text-5xl font-bold mb-8">{t("2023.title")}</h2>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            {t("2023.description")}
          </p>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            {t("2023.description.2")}
          </p>
        </div>
        <div class="bg-neutral-100 rounded-2xl p-8 text-center">
          <div class="flex justify-center mb-4">
            <img src="/partners/haileybury-astana.svg" alt="Haileybury Astana" class="h-12 opacity-80" />
          </div>
          <div class="w-full h-64 rounded-xl mb-4 overflow-hidden">
            <video 
              src={aphb2023Video} 
              autoplay 
              muted 
              loop 
              playsinline
              class="w-full h-full object-cover"
              aria-label="Участники APhB 2023 в Haileybury Astana">
            </video>
          </div>
               <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-6 mt-6 place-items-center">
                 <img src="/partners/american-corner.svg" alt="American Corner" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/beyond-curriculum.svg" alt="Beyond Curriculum" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/fly-arystan.svg" alt="Fly Arystan" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/kinematic.svg" alt="Kinematic" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/lever.svg" alt="Lever" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/maker-space.svg" alt="Maker Space" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/maple-bear.svg" alt="Maple Bear" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/rphms.svg" alt="RPHMS" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/ustem.svg" alt="USTEM" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                 <img src="/partners/stemolympiads.svg" alt="STEM Olympiads" class="h-7 md:h-9 lg:h-10 object-contain opacity-80 hover:opacity-100 transition-all duration-300 hover:scale-110" />
               </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2.5. Отзыв от Haileybury Astana -->
  <section class="col-span-full mb-20">
    <div class="max-w-4xl mx-auto">
      <blockquote class="bg-white border border-neutral-200 rounded-2xl p-8 lg:p-12 text-center">
        <p class="text-xl lg:text-2xl font-semibold text-neutral-800 mb-6 leading-relaxed">
          «{t("2023.testimonial.text")}»
        </p>
        <footer class="text-neutral-600 text-lg">
          {t("2023.testimonial.author")}
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- 3. Прорыв 2024 года -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="bg-gradient-to-br from-blue-50 to-indigo-100 border-2 border-blue-200 rounded-3xl p-8 lg:order-1 shadow-lg">
          <!-- Логотип университета -->
          <div class="flex justify-center mb-6">
            <div class="bg-white rounded-2xl p-4 shadow-md">
              <img src="/partners/satbayev_uni.svg" alt="Satbayev University" class="h-16 opacity-90" />
            </div>
          </div>
          
          <!-- Видео -->
          <div class="aspect-video rounded-2xl overflow-hidden mb-6 shadow-lg border-2 border-white">
            <iframe 
              width="100%" 
              height="100%" 
              src="https://www.youtube.com/embed/rStI6M0aaxc?si=blU-dKTYyQBJzpxj" 
              title="YouTube video player" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              referrerpolicy="strict-origin-when-cross-origin" 
              allowfullscreen
              class="w-full h-full">
            </iframe>
          </div>
          
          <p class="text-center text-lg font-semibold text-blue-900 mb-8">
            {t("2024.video.caption")}
          </p>
          
          <!-- Логотипы партнёров -->
          <div class="bg-white rounded-2xl p-6 shadow-md">
            <h4 class="text-center text-lg font-bold text-gray-800 mb-6">{t("2024.partners.title")}</h4>
            <div class="space-y-6">
              <!-- Основные логотипы -->
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 place-items-center">
                <img src="/partners/almaty-daryny.svg" alt="Almaty Daryny" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/chevron.svg" alt="Chevron" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/caravan.svg" alt="Caravan" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/lenovo.svg" alt="Lenovo" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/nis.svg" alt="NIS" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/sunmary.svg" alt="Sunmary" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/umag.svg" alt="UMag" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/ustem.svg" alt="USTEM" class="h-10 md:h-12 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/wolfram-alpha.svg" alt="Wolfram Alpha" class="h-14 md:h-16 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                <img src="/partners/zapis.svg" alt="Zapis" class="h-12 md:h-14 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
              </div>
              
              <!-- Министерства -->
              <div class="border-t border-gray-200 pt-4">
                <div class="flex justify-center gap-8">
                  <img src="/partners/ministry-of-education.svg" alt="Ministry of Education" class="h-8 md:h-10 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                  <img src="/partners/mnvo.svg" alt="MNVO" class="h-8 md:h-10 object-contain opacity-90 hover:opacity-100 transition-all duration-300 hover:scale-110" />
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="lg:order-2">
          <h2 class="text-3xl lg:text-5xl font-bold mb-8">{t("2024.title")}</h2>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            {t("2024.description.1")}
          </p>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            <strong>{t("2024.description.2")}</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3.5. Отзыв от Satbayev University -->
  <section class="col-span-full mb-20">
    <div class="max-w-4xl mx-auto">
      <blockquote class="bg-white border border-neutral-200 rounded-2xl p-8 lg:p-12 text-center">
        <p class="text-xl lg:text-2xl font-semibold text-neutral-800 mb-6 leading-relaxed">
          «{t("2024.testimonial.text")}»
        </p>
        <footer class="text-neutral-600 text-lg">
          {t("2024.testimonial.author")}
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- 4. Команда и волонтёры -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl lg:text-5xl font-bold mb-8">{t("team.title")}</h2>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            <strong>{t("team.description.1")}</strong>
          </p>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            {t("team.description.2")}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
            <div class="rounded-xl overflow-hidden">
              <img src={volunteer1Photo} alt="Волонтёры APhB" class="w-full h-48 object-cover" />
            </div>
            <div class="rounded-xl overflow-hidden">
              <img src={volunteer2Photo} alt="Волонтёры APhB" class="w-full h-48 object-cover" />
            </div>
            <div class="rounded-xl overflow-hidden">
              <img src={volunteer3Photo} alt="Волонтёры APhB" class="w-full h-48 object-cover" />
            </div>
          </div>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            {t("team.description.3")}
          </p>
        </div>
        <div class="bg-neutral-100 rounded-2xl p-8 text-center">
          <div class="w-full h-64 rounded-xl mb-4 overflow-hidden">
            <img src={volunteersPhoto} alt="Команда волонтёров и организаторов" class="w-full h-full object-cover" />
          </div>
          <p class="text-neutral-600">{t("team.jury.caption")}</p>  
        </div>
      </div>
    </div>
  </section>

  <!-- 4.5. Признание на государственном уровне -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl lg:text-5xl font-bold text-center mb-8">{t("recognition.title")}</h2>
      <p class="text-center text-lg text-neutral-600 mb-12 max-w-3xl mx-auto">
        {t("recognition.subtitle")}
      </p>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Расширенное заседание коллегии -->
        <div class="bg-gradient-to-br from-green-50 to-emerald-100 border-2 border-green-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 hover:scale-105">
          <div class="w-full h-48 rounded-xl mb-4 overflow-hidden border-2 border-white shadow-md">
            <img src="/photos/rashir.png" alt="Расширенное заседание коллегии Министерства науки и высшего образования РК" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold text-green-900 mb-3">{t("recognition.ministry.title")}</h3>
          <p class="text-green-800 text-sm leading-relaxed font-medium">
            {t("recognition.ministry.description")}
          </p>
        </div>

        <!-- Встреча с министром -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-100 border-2 border-blue-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 hover:scale-105">
          <div class="w-full h-48 rounded-xl mb-4 overflow-hidden border-2 border-white shadow-md">
            <img src="/photos/minister.png" alt="Встреча с министром науки и высшего образования РК" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold text-blue-900 mb-3">{t("recognition.minister.title")}</h3>
          <p class="text-blue-800 text-sm leading-relaxed font-medium">
            {t("recognition.minister.description")}
          </p>
        </div>

        <!-- Международный опыт -->
        <div class="bg-gradient-to-br from-purple-50 to-violet-100 border-2 border-purple-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 hover:scale-105">
          <div class="w-full h-48 rounded-xl mb-4 overflow-hidden border-2 border-white shadow-md">
            <img src="/photos/izho.png" alt="Обмен опытом с организатором IZhO 2024" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-bold text-purple-900 mb-3">{t("recognition.international.title")}</h3>
          <p class="text-purple-800 text-sm leading-relaxed font-medium">
            {t("recognition.international.description")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Поход в горы -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="bg-neutral-100 rounded-2xl p-8 text-center lg:order-1">
          <div class="w-full h-64 rounded-xl mb-4 overflow-hidden relative">
            <video 
              src={mountainHikeVideo} 
              autoplay 
              muted
              loop 
              playsinline
              class="w-full h-full object-cover"
              aria-label="Поход на Бутаковский водопад в горах Заилийского Алатау"
              controls>
            </video>
          </div>
        </div>
        <div class="lg:order-2">
          <h2 class="text-3xl lg:text-5xl font-bold mb-8">{t("more.title")}</h2>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            {t("more.description.1")}
          </p>
          <p class="text-lg text-neutral-700 mb-6 leading-relaxed">
            {t("more.description.2")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Партнёры -->
  {logos.length > 0 && (
    <section class="col-span-full mb-20">
      <h2 class="text-3xl lg:text-5xl font-bold text-center mb-8">{t("partners.title")}</h2>
      <p class="text-center text-lg text-neutral-600 mb-12 max-w-3xl mx-auto">
        {t("partners.subtitle")}
      </p>
      <div class="bg-white border border-neutral-200 rounded-2xl p-8 lg:p-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-8 lg:gap-12 place-items-center">
          {logos.map((logo) => (
            <div class="flex items-center justify-center p-4 hover:bg-neutral-50 rounded-xl transition-all duration-300 hover:scale-105">
              <img 
                src={logo.src} 
                alt={logo.alt} 
                loading="lazy" 
                class="max-h-12 lg:max-h-16 xl:max-h-20 w-auto object-contain opacity-75 hover:opacity-100 transition-opacity duration-300" 
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 7. Отзывы участников -->
  <section class="col-span-full mb-20">
    <h2 class="text-3xl lg:text-5xl font-bold text-center mb-12">{t("testimonials.title")}</h2>
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <div class="bg-white border border-neutral-200 rounded-2xl p-6">
            <p class="text-neutral-700 mb-4 leading-relaxed">
              "{testimonial.text}"
            </p>
            <div class="border-t border-neutral-200 pt-4">
              <p class="font-semibold text-neutral-800">{testimonial.author}</p>
              {testimonial.team && <p class="text-sm text-neutral-600">{t("testimonials.team_label")} "{testimonial.team}"</p>}
              <p class="text-sm text-neutral-500">{testimonial.school}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- 8. Партнёрство -->
  <section class="col-span-full mb-20">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl lg:text-5xl font-bold text-center mb-8">{t("partnership.title")}</h2>
      <p class="text-center text-lg text-neutral-600 mb-12 max-w-3xl mx-auto">
        {t("partnership.subtitle")}
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <!-- Как поддерживают нас -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-100 border border-blue-200 rounded-2xl p-8">
          <h3 class="text-2xl font-bold text-blue-900 mb-6">{t("partnership.support.title")}</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 bg-blue-600 rounded-full mt-2 flex-shrink-0"></div>
              <p class="text-blue-800"><strong>{t("partnership.support.financial")}</strong></p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 bg-blue-600 rounded-full mt-2 flex-shrink-0"></div>
              <p class="text-blue-800"><strong>{t("partnership.support.prizes")}</strong></p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 bg-blue-600 rounded-full mt-2 flex-shrink-0"></div>
              <p class="text-blue-800"><strong>{t("partnership.support.venues")}</strong></p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 bg-blue-600 rounded-full mt-2 flex-shrink-0"></div>
              <p class="text-blue-800"><strong>{t("partnership.support.expertise")}</strong></p>
            </div>
          </div>
        </div>

        <!-- Что получают партнёры -->
        <div class="bg-gradient-to-br from-green-50 to-emerald-100 border border-green-200 rounded-2xl p-8">
          <h3 class="text-2xl font-bold text-green-900 mb-6">{t("partnership.benefits.title")}</h3>
