---
import Layout from "~/components/layout.astro";
import { getLangFromUrl, useTranslations } from "~/utils/i18n";

import { RegisterForm } from "~/components/register";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations("apply", lang);
---

<Layout title={t("seo.title")} description={t("seo.description")} image="/og.png" grid={false}>
  <div class="col-span-full flex justify-center py-8 md:py-12 mb-16 relative z-20">
    <div class="w-full max-w-3xl px-1">
      <div class="text-center mb-8 md:mb-10">
        <h1 class="text-3xl md:text-5xl font-extrabold text-primary-900 mb-3">
          {t("formTitle")}
        </h1>
        <p class="text-neutral-600 md:text-lg max-w-xl mx-auto">
          {t("formSubtitle")}
        </p>
      </div>
      <RegisterForm client:load {lang} />
    </div>
  </div>
</Layout>
